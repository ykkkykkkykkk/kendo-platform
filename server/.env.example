# Turso (libSQL) 데이터베이스 접속 정보
# Turso 콘솔 > Database > Connect 에서 복사
TURSO_URL=libsql://kendo-platform-<your-username>.turso.io
TURSO_AUTH_TOKEN=<your-turso-auth-token>

# 서버 포트 (Render는 10000 권장)
PORT=4000

# JWT 서명 키 — 반드시 64자 이상 랜덤 값으로 교체
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHARS_BASE64

# 관리자 패널 내부 토큰 — 반드시 32자 이상 랜덤 값으로 교체 (사람이 직접 입력하지 않음)
# 생성: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
ADMIN_TOKEN=REPLACE_WITH_RANDOM_32_CHARS_BASE64

# 관리자 로그인 아이디/비밀번호 — 관리자 페이지 로그인에 사용
# 둘 다 설정하면 이 아이디/비번으로 로그인. 미설정 시 위 ADMIN_TOKEN을 비밀번호로 입력해 로그인(락아웃 방지)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# 허용할 프론트엔드 도메인 (CORS). 쉼표로 여러 개 가능
# 예: https://kendo.vercel.app,https://www.kendo.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app
